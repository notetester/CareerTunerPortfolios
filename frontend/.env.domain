# domain 모드 (vite build --mode domain).
# 도메인 네임 기반 운영 빌드 — 도메인 미확정이라 플레이스홀더(예: careertuner.kr).
# 웹을 API 와 같은 도메인에서 서빙한다면 VITE_API_BASE_URL 을 비워 상대경로 "/api" 를 쓰는 편이 낫다.
VITE_API_BASE_URL=https://api.careertuner.kr/api

# dev 서버 /api 프록시 대상 (도메인 모드로 dev 서버를 띄우는 경우)
VITE_PROXY_TARGET=https://api.careertuner.kr
