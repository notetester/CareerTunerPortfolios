# aws 모드 (vite --mode aws / vite build --mode aws).
# AWS 실배포 백엔드(https://careertuner.kro.kr)를 가리키는 빌드 — 앱(APK) 번들이 이 모드를 쓴다.
# 웹은 nginx 가 같은 도메인에서 서빙하므로 상대경로(/api) 기본 빌드를 쓰고,
# 앱(capacitor 번들)은 origin 이 http://localhost 라 절대주소가 필요해 이 모드로 빌드한다.
VITE_API_BASE_URL=https://careertuner.kro.kr/api

# dev 서버 /api 프록시 대상 — dev:aws 는 로컬 Vite 에서 배포 백엔드로 프록시해 확인하는 용도.
VITE_PROXY_TARGET=https://careertuner.kro.kr
