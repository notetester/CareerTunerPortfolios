# aws 모드 (vite --mode aws / vite build --mode aws).
# AWS 배포 백엔드를 가리키는 빌드 — 공인 주소 미확정이라 플레이스홀더(CHANGEME).
# 주소 확정 시 이 파일만 교체하면 된다 (config/environments.json 과 함께 갱신할 것).
VITE_API_BASE_URL=http://CHANGEME-aws-api:8080/api

# dev 서버 /api 프록시 대상 — dev:aws 는 로컬 Vite 에서 AWS 백엔드로 프록시해 확인하는 용도.
VITE_PROXY_TARGET=http://CHANGEME-aws-api:8080
