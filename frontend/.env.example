# CareerTuner 프런트엔드 환경변수 예시.
# 이 파일은 커밋되며(.env 만 gitignore), 실제 값은 .env 또는 배포 환경변수로 주입한다.
#
# ── Web Push (VAPID) ─────────────────────────────────────────────
# 브라우저/PWA 푸시 구독에 쓰는 공개키. 비밀이 아니며 백엔드의
# careertuner.push.vapid.public-key 기본값과 반드시 동일해야 한다.
# 미설정 시 src/platform/push.ts 의 개발용 기본 공개키로 동작한다.
VITE_VAPID_PUBLIC_KEY=BIHnlq45n0TUTYx1XCkGjMpap8v_GHYBKqUjrx9O3npe7HL2Nz1TU28u0Kh17q4QjP3w8ZXGJn1RIRQ25SR5Elk

# ── API 베이스 URL ───────────────────────────────────────────────
# 기본: 상대경로 "/api" (웹은 Vite 프록시 → :8080, 배포는 동일 출처 백엔드).
# 네이티브 앱(Capacitor)은 상대경로로 PC localhost 에 닿지 못하므로, 도달 가능한 백엔드의
# 절대 URL 로 빌드한다(백엔드 CORS_ALLOWED_ORIGINS 허용 필요).
#   예) 같은 LAN PC 백엔드: VITE_API_BASE_URL=http://192.168.0.10:8080/api
# VITE_API_BASE_URL=http://192.168.0.10:8080/api

# ── Mock 모드 ────────────────────────────────────────────────────
# 백엔드 없이 mock 레지스트리로 동작(데모/APK). vite --mode mock 시 .env.mock 가 우선한다.
# VITE_USE_MOCK=true
