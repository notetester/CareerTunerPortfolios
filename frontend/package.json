    "mobile:apk": "cd android && gradlew assembleDebug",
    "mobile:apk:release": "cd android && gradlew assembleRelease",
    "mobile:aab": "cd android && gradlew bundleRelease",
    "ios:sync": "vite build --mode mock && cap sync ios",
    "demo:apk": "node scripts/build-demo-apk.mjs"
