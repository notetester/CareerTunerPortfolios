# tailscale 모드 (vite --mode tailscale / vite build --mode tailscale).
# 팀 표준 원격 접속 환경 — 백엔드는 tailscale serve(HTTPS) 뒤의 개발 PC.
#
# 앱/원격 웹이 API 를 절대 URL 로 직접 호출한다(백엔드 CORS 허용 필요).
# 마이크/카메라(getUserMedia)는 HTTPS 필수라 tailnet 접속은 https://<machine>.ts.net 로 붙는다.
VITE_API_BASE_URL=https://careertuner-dev.example.invalid/api

# dev 서버 /api 프록시 대상 — dev:tailscale 은 개발 PC 에서 실행되므로 로컬 백엔드로 프록시한다.
VITE_PROXY_TARGET=http://localhost:8080
