# localhost 모드 (vite --mode localhost / vite build --mode localhost).
# 기본 `npm run dev` 와 동일한 환경을 이름으로 명시한 것 — 내 PC 백엔드(:8080)를 사용한다.
#
# 웹은 상대경로 "/api"(VITE_API_BASE_URL 비움) + dev 프록시로 백엔드에 붙는 것이 표준.
# 네이티브 앱(APK)에서 로컬 백엔드를 쓰려면 기기에서 localhost 로 PC 에 닿을 수 없으므로,
# 설정 화면의 "서버 주소" 런타임 오버라이드(예: http://192.168.0.10:8080/api)를 사용한다.
VITE_API_BASE_URL=

# dev 서버 /api 프록시 대상 (vite.config.ts 가 loadEnv 로 읽는다)
VITE_PROXY_TARGET=http://localhost:8080
