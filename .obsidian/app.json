{
  "attachmentFolderPath": "docs/obsidian-vault/attachments",
  "newFileLocation": "folder",
  "newFileFolderPath": "docs/obsidian-vault/inbox",
  "useMarkdownLinks": true,
  "newLinkFormat": "relative",
