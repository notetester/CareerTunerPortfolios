    "node_modules/",
    "backend/.gradle/",
    "backend/build/",
    "backend/data/",
    "backend/logs/",
    "frontend/node_modules/",
    "frontend/dist/",
    "frontend/dist-apk/",
    "frontend/android/.gradle/",
    "frontend/android/build/",
    "frontend/android/app/build/",
    "desktop/build-*/",
    "logs/",
    "*.log",
    "*.class"
  ]
}
