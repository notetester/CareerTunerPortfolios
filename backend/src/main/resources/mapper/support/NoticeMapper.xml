<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.careertuner.support.mapper.NoticeMapper">

    <resultMap id="noticeResult" type="com.careertuner.support.domain.Notice">
        <id     property="id"           column="id"/>
        <result property="title"        column="title"/>
        <result property="content"      column="content"/>
        <result property="category"     column="category"/>
        <result property="status"       column="status"/>
        <result property="pinned"       column="is_pinned"/>
        <result property="thumbnailUrl" column="thumbnail_url"/>
        <result property="adminId"      column="admin_id"/>
        <result property="viewCount"    column="view_count"/>
        <result property="publishedAt"  column="published_at"/>
        <result property="createdAt"    column="created_at"/>
        <result property="updatedAt"    column="updated_at"/>
    </resultMap>

    <select id="findAllPublished" resultMap="noticeResult">
        SELECT id, title, content, category, status, is_pinned, thumbnail_url,
               admin_id, view_count, published_at, created_at, updated_at
          FROM notice
         WHERE status = 'PUBLISHED'
         ORDER BY is_pinned DESC, published_at DESC, created_at DESC
    </select>

    <select id="findById" resultMap="noticeResult">
        SELECT id, title, content, category, status, is_pinned, thumbnail_url,
               admin_id, view_count, published_at, created_at, updated_at
          FROM notice
         WHERE id = #{id}
           AND status = 'PUBLISHED'
    </select>

    <update id="incrementViewCount">
        UPDATE notice
           SET view_count = view_count + 1
         WHERE id = #{id}
    </update>

</mapper>
