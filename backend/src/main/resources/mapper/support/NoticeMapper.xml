<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.careertuner.support.mapper.NoticeMapper">

    <resultMap id="noticeResult" type="com.careertuner.support.domain.Notice">
        <id     property="id"           column="id"/>
        <result property="title"        column="title"/>
        <result property="content"      column="content"/>
        <result property="category"     column="category"/>
        <result property="status"       column="status"/>
        <result property="pinned"       column="is_pinned"/>
        <result property="thumbnailUrl" column="thumbnail_url"/>
        <result property="adminId"      column="admin_id"/>
        <result property="viewCount"    column="view_count"/>
        <result property="scheduledAt"  column="scheduled_at"/>
        <result property="publishedAt"  column="published_at"/>
        <result property="createdAt"    column="created_at"/>
        <result property="updatedAt"    column="updated_at"/>
    </resultMap>

    <!--
      공개 노출 = 즉시발행(PUBLISHED) + 예약 발행 중 시각이 지난 건(SCHEDULED & scheduled_at<=현재(KST)).
      약관/가이드라인과 동일하게 상태를 승격하지 않고 "조회 시점 판정"으로 노출한다.
      비교 기준은 KST(+09:00): UTC_TIMESTAMP()(세션 무관 UTC) + 9h (LegalMapper 검증 표현 재사용).
      정렬은 발행 시각 — PUBLISHED 는 published_at, 아직 published_at 없는 SCHEDULED 는 scheduled_at(COALESCE).
    -->
    <select id="findAllPublished" resultMap="noticeResult">
        SELECT id, title, content, category, status, is_pinned, thumbnail_url,
               admin_id, view_count, scheduled_at, published_at, created_at, updated_at
          FROM notice
         WHERE status = 'PUBLISHED'
            OR (status = 'SCHEDULED' AND scheduled_at &lt;= (UTC_TIMESTAMP() + INTERVAL 9 HOUR))
         ORDER BY is_pinned DESC, COALESCE(published_at, scheduled_at) DESC, created_at DESC
    </select>

    <select id="findById" resultMap="noticeResult">
        SELECT id, title, content, category, status, is_pinned, thumbnail_url,
               admin_id, view_count, scheduled_at, published_at, created_at, updated_at
          FROM notice
         WHERE id = #{id}
           AND (status = 'PUBLISHED'
                OR (status = 'SCHEDULED' AND scheduled_at &lt;= (UTC_TIMESTAMP() + INTERVAL 9 HOUR)))
    </select>

    <update id="incrementViewCount">
        UPDATE notice
           SET view_count = view_count + 1
         WHERE id = #{id}
    </update>

</mapper>
