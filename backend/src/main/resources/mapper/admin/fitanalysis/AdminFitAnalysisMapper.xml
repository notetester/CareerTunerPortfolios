<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.careertuner.admin.fitanalysis.mapper.AdminFitAnalysisMapper">

    <resultMap id="AdminFitAnalysisResultMap" type="com.careertuner.admin.fitanalysis.domain.AdminFitAnalysisResult">
        <id property="id" column="id"/>
        <result property="applicationCaseId" column="application_case_id"/>
        <result property="userId" column="user_id"/>
        <result property="userName" column="user_name"/>
        <result property="userEmail" column="user_email"/>
        <result property="companyName" column="company_name"/>
        <result property="jobTitle" column="job_title"/>
        <result property="applicationStatus" column="application_status"/>
        <result property="favorite" column="is_favorite"/>
        <result property="fitScore" column="fit_score"/>
        <result property="matchedSkills" column="matched_skills"/>
        <result property="missingSkills" column="missing_skills"/>
        <result property="recommendedStudy" column="recommended_study"/>
        <result property="recommendedCertificates" column="recommended_certificates"/>
        <result property="strategy" column="strategy"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <sql id="AdminFitAnalysisColumns">
        fa.id,
        fa.application_case_id,
        users.id AS user_id,
        users.name AS user_name,
        users.email AS user_email,
        ac.company_name,
        ac.job_title,
        ac.status AS application_status,
        ac.is_favorite,
        fa.fit_score,
        fa.matched_skills,
        fa.missing_skills,
        fa.recommended_study,
        fa.recommended_certificates,
        fa.strategy,
        fa.created_at
    </sql>

    <select id="findLatestAll" resultMap="AdminFitAnalysisResultMap">
        SELECT
        <include refid="AdminFitAnalysisColumns"/>
        FROM fit_analysis fa
        INNER JOIN application_case ac ON ac.id = fa.application_case_id
        INNER JOIN users ON users.id = ac.user_id
        WHERE fa.id = (
            SELECT MAX(latest_fa.id)
            FROM fit_analysis latest_fa
            WHERE latest_fa.application_case_id = fa.application_case_id
        )
        ORDER BY fa.created_at DESC, fa.id DESC
    </select>

    <select id="findById" resultMap="AdminFitAnalysisResultMap">
        SELECT
        <include refid="AdminFitAnalysisColumns"/>
        FROM fit_analysis fa
        INNER JOIN application_case ac ON ac.id = fa.application_case_id
        INNER JOIN users ON users.id = ac.user_id
        WHERE fa.id = #{id}
    </select>
</mapper>
