<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.careertuner.admin.notification.mapper.AdminCampaignRecipientMapper">

    <!-- 캠페인 알림 팬아웃 대상: 활성(ACTIVE) 사용자 전체 -->
    <select id="findActiveUserIds" resultType="long">
        SELECT id
        FROM users
        WHERE status = 'ACTIVE'
        ORDER BY id
    </select>

</mapper>
