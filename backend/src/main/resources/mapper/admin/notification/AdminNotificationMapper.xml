<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.careertuner.admin.notification.mapper.AdminNotificationMapper">

    <resultMap id="adminNotificationResult" type="com.careertuner.admin.notification.dto.AdminNotificationResponse">
        <id     property="id"             column="id"/>
        <result property="userId"         column="user_id"/>
        <result property="recipientName"  column="recipient_name"/>
        <result property="recipientEmail" column="recipient_email"/>
        <result property="type"           column="type"/>
        <result property="title"          column="title"/>
        <result property="message"        column="message"/>
        <result property="read"           column="is_read"/>
        <result property="readAt"         column="read_at"/>
        <result property="createdAt"      column="created_at"/>
    </resultMap>

    <select id="findRecent" resultMap="adminNotificationResult">
        SELECT n.id,
               n.user_id,
               COALESCE(u.name, '탈퇴 회원')  AS recipient_name,
               COALESCE(u.email, '')          AS recipient_email,
               n.type,
               n.title,
               n.message,
               n.is_read,
               n.read_at,
               n.created_at
          FROM notification n
          LEFT JOIN users u ON u.id = n.user_id
         ORDER BY n.created_at DESC
         LIMIT #{limit}
    </select>

    <select id="countAll" resultType="long">
        SELECT COUNT(*) FROM notification
    </select>

    <select id="countRead" resultType="long">
        SELECT COUNT(*) FROM notification WHERE is_read = 1
    </select>

    <select id="countByType" resultType="java.util.Map">
        SELECT type                                         AS type,
               COUNT(*)                                     AS sent,
               SUM(CASE WHEN is_read = 1 THEN 1 ELSE 0 END) AS `read`
          FROM notification
         GROUP BY type
    </select>

    <select id="countByDayLast7" resultType="java.util.Map">
        SELECT DATE_FORMAT(created_at, '%Y-%m-%d') AS day,
               COUNT(*)                            AS cnt
          FROM notification
         WHERE created_at >= CURDATE() - INTERVAL 6 DAY
         GROUP BY DATE_FORMAT(created_at, '%Y-%m-%d')
    </select>

</mapper>
