<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.careertuner.admin.chatbot.mapper.AdminChatbotConversationMapper">

    <select id="findRecent" resultType="com.careertuner.admin.chatbot.dto.AdminChatbotConversationRow">
        SELECT conversation_id AS conversationId,
               user_id         AS userId,
               JSON_LENGTH(messages_json) AS messageCount,
               updated_at      AS updatedAt
          FROM chatbot_conversation_memory
        <where>
            <if test="userId != null">AND user_id = #{userId}</if>
        </where>
         ORDER BY updated_at DESC
         LIMIT #{limit}
    </select>

    <delete id="deleteConversation">
        DELETE FROM chatbot_conversation_memory WHERE conversation_id = #{conversationId}
    </delete>

</mapper>
