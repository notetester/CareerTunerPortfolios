<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.careertuner.legal.mapper.LegalMapper">

    <resultMap id="versionResult" type="com.careertuner.legal.domain.LegalDocumentVersion">
        <id     property="id"            column="id"/>
        <result property="docType"       column="doc_type"/>
        <result property="versionLabel"  column="version_label"/>
        <result property="status"        column="status"/>
        <result property="summary"       column="summary"/>
        <result property="adverse"       column="is_adverse"/>
        <result property="effectiveDate" column="effective_date"/>
        <result property="publishedAt"   column="published_at"/>
        <result property="adminId"       column="admin_id"/>
        <result property="createdAt"     column="created_at"/>
        <result property="updatedAt"     column="updated_at"/>
    </resultMap>

    <resultMap id="clauseResult" type="com.careertuner.legal.domain.LegalClause">
        <id     property="id"        column="id"/>
        <result property="versionId" column="version_id"/>
        <result property="seq"       column="seq"/>
        <result property="title"     column="title"/>
        <result property="body"      column="body"/>
    </resultMap>

    <!--
      현재 시행본(live) 1건.
      PUBLISHED 중 effective_date<=NOW() 의 effective_date 최댓값 1건.
      동률(동일 effective_date)이면 effective_date DESC, published_at DESC, id DESC 로 결정적 1건.
      NOW() 비교는 DB 세션 타임존 기준.
    -->
    <select id="findLiveVersion" resultMap="versionResult">
        SELECT id, doc_type, version_label, status, summary, is_adverse,
               effective_date, published_at, admin_id, created_at, updated_at
          FROM legal_document_version
         WHERE doc_type = #{docType}
           AND status = 'PUBLISHED'
           AND effective_date &lt;= NOW()
         ORDER BY effective_date DESC, published_at DESC, id DESC
         LIMIT 1
    </select>

    <select id="findClausesByVersionId" resultMap="clauseResult">
        SELECT id, version_id, seq, title, body
          FROM legal_clause
         WHERE version_id = #{versionId}
         ORDER BY seq ASC, id ASC
    </select>

</mapper>
