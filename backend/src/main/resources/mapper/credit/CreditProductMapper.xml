<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.careertuner.credit.mapper.CreditProductMapper">

    <!-- 활성화된 충전 상품만 노출한다. 가격 변경은 DB row 수정으로 반영한다. -->
    <select id="findEnabledProducts" resultType="com.careertuner.credit.domain.CreditProduct">
        SELECT id,
               code,
               name,
               price,
               credit_amount,
               description,
               badge,
               enabled,
               sort_order,
               created_at,
               updated_at
          FROM credit_product
         WHERE enabled = 1
         ORDER BY sort_order ASC, id ASC
    </select>
</mapper>
