<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.careertuner.companyanalysis.mapper.CompanySearchCacheMapper">

    <!--
      upsert 계약(235 §6 · D-4a): query_key 충돌 시 results·fetched_at 만 갱신하고
      created_at 은 UPDATE 절에서 제외해 최초 생성 시각을 보존한다.
      results="[]" 도 그대로 저장한다(빈 결과는 HIT 대상 — 서비스 계층에서 hit/miss 판정).
    -->
    <insert id="upsertSearchCache">
        INSERT INTO company_search_cache
            (query_key, results, fetched_at)
        VALUES
            (#{queryKey}, #{results}, #{fetchedAt})
        ON DUPLICATE KEY UPDATE
            results = #{results},
            fetched_at = #{fetchedAt}
    </insert>

    <select id="findByQueryKey" resultType="com.careertuner.companyanalysis.domain.CompanySearchCache">
        SELECT *
        FROM company_search_cache
        WHERE query_key = #{queryKey}
    </select>
</mapper>
