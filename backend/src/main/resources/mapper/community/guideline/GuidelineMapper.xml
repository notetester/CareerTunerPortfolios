<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.careertuner.community.guideline.mapper.GuidelineMapper">

  <resultMap id="guidelineResult" type="com.careertuner.community.guideline.dto.GuidelineResponse">
    <id property="id" column="id"/>
    <result property="versionLabel" column="version_label"/>
    <result property="lede" column="lede"/>
    <result property="oksJson" column="oks_json"/>
    <result property="nosJson" column="nos_json"/>
    <result property="rulesJson" column="rules_json"/>
    <result property="paramsJson" column="params_json"/>
    <result property="publishedAt" column="published_at"/>
  </resultMap>

  <select id="findPublished" resultMap="guidelineResult">
    SELECT id, version_label, lede, oks_json, nos_json, rules_json, params_json, published_at
    FROM community_guideline
    WHERE status = 'PUBLISHED'
    ORDER BY published_at DESC
    LIMIT 1
  </select>

</mapper>
